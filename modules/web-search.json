{
  "name": "webSearch",
  "label": "Web Search",
  "description": "Run a web search (Bing or Brave) and return ranked results as structured data.",
  "moduleType": "search",
  "connection": "crawlora",
  "note": "Web Search queries Bing or Brave; the engine is chosen by the 'engine' parameter.",
  "communication": {
    "url": "{{if(parameters.engine = \"brave\"; \"/brave/search\"; \"/bing/search\")}}",
    "method": "GET",
    "qs": {
      "q": "{{parameters.q}}",
      "country": "{{parameters.country}}",
      "lang": "{{parameters.language}}",
      "count": "{{parameters.limit}}",
      "page": "{{parameters.page}}"
    },
    "response": {
      "iterate": "{{body.data.results}}",
      "output": {
        "position": "{{item.position}}",
        "title": "{{item.title}}",
        "link": "{{item.url}}",
        "snippet": "{{item.description}}",
        "source": "{{item.hostname}}"
      }
    }
  },
  "mappableParameters": [
    { "name": "q", "type": "text", "label": "Search query", "required": true },
    {
      "name": "engine",
      "type": "select",
      "label": "Search engine",
      "options": [
        { "label": "Bing", "value": "bing" },
        { "label": "Brave", "value": "brave" }
      ],
      "default": "bing"
    },
    { "name": "country", "type": "text", "label": "Country", "default": "us", "help": "Two-letter country code, e.g. us, gb, de." },
    { "name": "language", "type": "text", "label": "Language", "default": "en-us", "help": "ll-cc format (e.g. en-us, en-gb, de-de); Bing/Brave reject bare codes like 'en'." },
    { "name": "limit", "type": "number", "label": "Number of results", "default": 10, "help": "Bing supports up to 50." },
    { "name": "page", "type": "number", "label": "Page", "default": 1 }
  ],
  "interface": [
    { "name": "position", "type": "number", "label": "Position" },
    { "name": "title", "type": "text", "label": "Title" },
    { "name": "link", "type": "url", "label": "Link" },
    { "name": "snippet", "type": "text", "label": "Snippet" },
    { "name": "source", "type": "text", "label": "Source" }
  ],
  "samples": {
    "position": 1,
    "title": "OpenAI - Reddit",
    "link": "https://www.reddit.com/r/OpenAI/",
    "snippet": "OpenAI is an AI research and deployment company...",
    "source": "www.reddit.com"
  }
}
